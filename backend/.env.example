# ---- Database ----
# Dev default is SQLite (no setup required). For production, point this at Postgres, e.g.:
#   postgresql+psycopg2://USER:PASSWORD@HOST:5432/DBNAME
DATABASE_URL=sqlite:///./library.db

# ---- Auth ----
# Generate a strong value for production, e.g.:  python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ---- CORS (comma-separated origins allowed to call the API) ----
CORS_ORIGINS=http://localhost:8501,http://localhost:5173

# ---- Domain rules (ported from the original Tkinter app) ----
BORROW_LIMIT=5
GRACE_PERIOD_DAYS=2
BASE_PENALTY_RATE=1
MAX_PENALTY=50

# ---- Initial librarian account (used by seed_data.py) ----
ADMIN_USERNAME=admin
# Leave ADMIN_PASSWORD blank to have the seed script generate & print a random one.
ADMIN_PASSWORD=

# ---- AI features (Claude API) ----
# Leave ANTHROPIC_API_KEY blank to disable AI endpoints (they return 503; the rest works).
# Get a key at https://console.anthropic.com/ .
ANTHROPIC_API_KEY=
# Swap to claude-haiku-4-5 for lower cost/latency if you prefer.
AI_MODEL=claude-opus-4-8
