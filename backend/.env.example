# ---- Database ----
# Local SQLite by design (no setup required). Routed through SQLAlchemy, but this
# project is not intended to run on another backend — see the root README.
DATABASE_URL=sqlite:///./library.db

# ---- Auth ----
# Set a strong value, e.g.:  python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ---- CORS (comma-separated origins allowed to call the API) ----
CORS_ORIGINS=http://localhost:8501,http://localhost:5173

# ---- Domain rules (ported from the original Tkinter app) ----
BORROW_LIMIT=5
GRACE_PERIOD_DAYS=2
BASE_PENALTY_RATE=1
MAX_PENALTY=50

# ---- Initial librarian account (used by seed_data.py) ----
ADMIN_USERNAME=admin
# Leave ADMIN_PASSWORD blank to have the seed script generate & print a random one.
ADMIN_PASSWORD=

# ---- AI features (Google Gemini) ----
# Leave GEMINI_API_KEY blank to disable AI endpoints (they return 503; the rest works).
# Get a key at https://aistudio.google.com/apikey .
GEMINI_API_KEY=
# gemini-2.5-flash is fast + cheap; use gemini-2.5-pro for higher quality.
GEMINI_MODEL=gemini-2.5-flash
# Embedding model for semantic search (run `python -m app.seed_embeddings` to backfill).
EMBEDDING_MODEL=gemini-embedding-001
